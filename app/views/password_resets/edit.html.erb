<!DOCTYPE html>
<html>
  <head>
    <title>Reset Password</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #0b1220;
        color: #0b1220;
      }

      .wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      .card {
        width: 100%;
        max-width: 420px;
        background: #ffffff;
        border-radius: 20px;
        padding: 24px;
        box-sizing: border-box;
      }

      h1 {
        margin: 0 0 8px 0;
        font-size: 28px;
      }

      p.sub {
        margin: 0 0 18px 0;
        color: #667085;
      }

      .error {
        background: #fef3f2;
        color: #b42318;
        border: 1px solid #fecdca;
        border-radius: 12px;
        padding: 12px;
        margin-bottom: 14px;
      }

      label {
        display: block;
        font-size: 14px;
        margin: 14px 0 6px;
        font-weight: 600;
      }

      .input-wrap {
        position: relative;
      }

      input {
        width: 100%;
        box-sizing: border-box;
        padding: 14px 52px 14px 16px;
        border-radius: 14px;
        border: 1px solid #d7dee8;
        font-size: 16px;
      }

      input:focus {
        outline: none;
        border-color: #1e73e8;
        box-shadow: 0 0 0 3px rgba(30, 115, 232, 0.12);
      }

      .toggle-password {
        position: absolute;
        top: 50%;
        right: 14px;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        color: #667085;
        cursor: pointer;
        padding: 4px;
        margin: 0;
        width: auto;
        font-size: 14px;
        font-weight: 700;
        line-height: 1;
      }

      .toggle-password:hover {
        color: #1e73e8;
      }

      .submit-btn {
        width: 100%;
        margin-top: 18px;
        border: 0;
        border-radius: 999px;
        padding: 15px 18px;
        background: #1e73e8;
        color: white;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: opacity 0.2s ease, transform 0.2s ease;
      }

      .submit-btn:hover {
        opacity: 0.95;
      }

      .submit-btn:disabled {
        opacity: 0.75;
        cursor: not-allowed;
      }

      .spinner {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255, 255, 255, 0.35);
        border-top-color: #ffffff;
        border-radius: 50%;
        animation: spin 0.75s linear infinite;
        display: none;
        flex-shrink: 0;
      }

      .submit-btn.loading .spinner {
        display: inline-block;
      }

      @keyframes spin {
        to {
          transform: rotate(360deg);
        }
      }

      .email {
        font-size: 14px;
        color: #667085;
        margin-bottom: 8px;
        word-break: break-word;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>Reset Password</h1>
        <p class="sub">Enter your new password below.</p>

        <div class="email"><strong>Email:</strong> <%= @email %></div>

        <% if @error.present? %>
          <div class="error"><%= @error %></div>
        <% end %>

        <%= form_with url: "/password_resets", method: :patch, local: true, html: { id: "reset-password-form" } do %>
          <%= hidden_field_tag :token, @token %>
          <%= hidden_field_tag :email, @email %>

          <label for="password">New password</label>
          <div class="input-wrap">
            <%= password_field_tag :password, nil, id: "password", required: true, minlength: 8, autocomplete: "new-password" %>
            <button type="button" class="toggle-password" data-target="password">Show</button>
          </div>

          <label for="password_confirmation">Confirm new password</label>
          <div class="input-wrap">
            <%= password_field_tag :password_confirmation, nil, id: "password_confirmation", required: true, minlength: 8, autocomplete: "new-password" %>
            <button type="button" class="toggle-password" data-target="password_confirmation">Show</button>
          </div>

          <button type="submit" class="submit-btn" id="submit-btn">
            <span class="spinner" aria-hidden="true"></span>
            <span class="submit-label">Reset Password</span>
          </button>
        <% end %>
      </div>
    </div>

    <script>
      document.querySelectorAll(".toggle-password").forEach(function(button) {
        button.addEventListener("click", function() {
          var targetId = button.getAttribute("data-target");
          var input = document.getElementById(targetId);

          if (!input) return;

          if (input.type === "password") {
            input.type = "text";
            button.textContent = "Hide";
          } else {
            input.type = "password";
            button.textContent = "Show";
          }
        });
      });

      var form = document.getElementById("reset-password-form");
      var submitBtn = document.getElementById("submit-btn");

      if (form && submitBtn) {
        form.addEventListener("submit", function() {
          submitBtn.disabled = true;
          submitBtn.classList.add("loading");

          var label = submitBtn.querySelector(".submit-label");
          if (label) label.textContent = "Resetting...";
        });
      }
    </script>
  </body>
</html>