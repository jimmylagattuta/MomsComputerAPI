<!DOCTYPE html>
<html>
  <head>
    <title>Password Reset Complete</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #0b1220;
        color: #0b1220;
      }

      .wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
      }

      .card {
        width: 100%;
        max-width: 420px;
        background: #ffffff;
        border-radius: 20px;
        padding: 24px;
        box-sizing: border-box;
        text-align: center;
      }

      h1 {
        margin: 0 0 10px 0;
        font-size: 28px;
      }

      p {
        color: #667085;
        margin-bottom: 18px;
      }

      a {
        display: inline-block;
        text-decoration: none;
        background: #1e73e8;
        color: white;
        padding: 14px 20px;
        border-radius: 999px;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="card">
        <h1>Password Reset Complete</h1>
        <p>Your password has been updated successfully. You can return to the app and sign in with your new password.</p>
      </div>
    </div>
  </body>
</html>